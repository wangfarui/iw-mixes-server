# Copy to /etc/iw-mixes/iw-external.env on the public server.
# Do not commit the real file.

JAVA_OPTS=-Xms64m -Xmx256m -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/var/log/iw-mixes/iw-external-oom.hprof

IW_WEB_ENV=prod
IW_WEB_API_PREFIX=/
IW_EXTERNAL_PORT=18006
IW_CORE_BASE_URL=http://<private-java-server-ip>:18080

IW_DB_DRIVER_CLASS=com.mysql.cj.jdbc.Driver
IW_DB_URL=jdbc:mysql://127.0.0.1:3306/iw_mixes?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
IW_DB_USERNAME=iw_mixes
IW_DB_PASSWORD=change-me

IW_REDIS_HOST=127.0.0.1
IW_REDIS_PORT=6379
IW_REDIS_DATABASE=0
IW_REDIS_USERNAME=
IW_REDIS_PASSWORD=change-me

IW_INTERNAL_SECRET=change-me-long-random-secret
IW_AI_DEFAULT_API_URL=https://api.deepseek.com/chat/completions
IW_AI_DEFAULT_API_KEY=
IW_AI_DEFAULT_MODEL=gpt-5.5
IW_AI_DEFAULT_REASONING_EFFORT=medium
IW_AI_IMAGE_PROVIDER=gemini
IW_AI_IMAGE_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
IW_AI_IMAGE_API_KEY=
IW_AI_IMAGE_MODEL=gemini-3.1-flash-image
IW_AI_IMAGE_SOURCE_BASE_URL=https://example-bucket.oss-cn-region.aliyuncs.com/iw-core/
IW_AI_IMAGE_REQUEST_TIMEOUT_MS=720000
IW_AI_IMAGE_SOURCE_DOWNLOAD_TIMEOUT_MS=30000
IW_AI_IMAGE_MAX_BYTES=10485760

IW_EXTERNAL_DAILYHOT_TIMEOUT_MS=3000
IW_EXTERNAL_DAILYHOT_CACHE_SECONDS=1800

BLOG_ACCESS_ALLOWED_ORIGINS=https://blog.itwray.com,http://localhost:4000
BLOG_ACCESS_TOKEN_SECRET=
BLOG_ACCESS_DEFAULT_EXPIRES_IN=86400
BLOG_ACCESS_SCOPE_LIFE_PASSWORD_HASH=
BLOG_ACCESS_SCOPE_LIFE_KEY=

ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_EMAIL_ACCESS_KEY_ID=
ALIYUN_EMAIL_ACCESS_KEY_SECRET=
ALIYUN_EMAIL_ACCOUNT_NAME=
ALIYUN_EMAIL_FROM_ALIAS=
ALIYUN_ASR_ACCESS_KEY_ID=
ALIYUN_ASR_ACCESS_KEY_SECRET=
ALIYUN_ASR_APP_KEY=
ALIYUN_ASR_FFMPEG_COMMAND=ffmpeg

IW_EXTERNAL_AMAP_KEY=
IW_EXTERNAL_UPTIMEROBOT_KEY=
IW_EXTERNAL_EXCHANGE_RATE_KEY=
IW_DING_TALK_ENABLED=false
IW_DING_TALK_ACCESS_TOKEN=
IW_DING_TALK_SECRET=
