# Copy to /etc/iw-mixes/iw-core.env on the private Java server.
# Do not commit the real file.

JAVA_OPTS=-Xms128m -Xmx512m -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/var/log/iw-mixes/iw-core-oom.hprof

IW_WEB_ENV=prod
IW_WEB_API_PREFIX=/
IW_CORE_PORT=18080

IW_DB_DRIVER_CLASS=com.mysql.cj.jdbc.Driver
IW_DB_URL=jdbc:mysql://<mysql-private-ip>:3306/iw_mixes?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
IW_DB_USERNAME=iw_mixes
IW_DB_PASSWORD=change-me

IW_REDIS_HOST=<redis-private-ip>
IW_REDIS_PORT=6379
IW_REDIS_DATABASE=0
IW_REDIS_USERNAME=
IW_REDIS_PASSWORD=change-me

IW_INTERNAL_SECRET=change-me-long-random-secret
IW_EXTERNAL_BASE_URL=http://<public-server-private-ip>:18006
IW_EXTERNAL_FEIGN_CONNECT_TIMEOUT_MS=5000
IW_EXTERNAL_FEIGN_READ_TIMEOUT_MS=180000
IW_AUTH_APPLICATION_ACCOUNT_AES_KEY=0123456789abcdef0123456789abcdef
IW_AUTH_MANAGED_SECRET_AES_KEY=<generate-a-random-32-character-secret>

# Optional: file upload / ASR settings used by auth and bookkeeping features.
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_EMAIL_ACCOUNT_NAME=
ALIYUN_EMAIL_FROM_ALIAS=Wray
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BASE_URL=
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET_NAME=
ALIYUN_OSS_UPLOAD_PARENT_DIR=
